{
  "name": "@doremijs/o2t",
  "version": "0.1.11",
  "description": "OpenAPI to TypeScript code generator",
  "keywords": [
    "openapi",
    "swagger",
    "typescript",
    "code generator"
  ],
  "type": "module",
  "sideEffects": false,
  "license": "LGPL-3.0-or-later",
  "author": "erguotou <erguotou525@gmail.com>",
  "main": "dist/index.js",
  "files": [
    "bin/o2t.mjs",
    "dist"
  ],
  "bin": {
    "o2t": "bin/o2t.mjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client/index.d.ts",
        "default": "./dist/client/index.mjs"
      },
      "require": {
        "types": "./dist/client/index.d.ts",
        "default": "./dist/client/index.js"
      }
    },
    "./client/fetch": {
      "import": {
        "types": "./dist/client/fetch.d.ts",
        "default": "./dist/client/fetch.mjs"
      },
      "require": {
        "types": "./dist/client/fetch.d.ts",
        "default": "./dist/client/fetch.js"
      }
    },
    "./client/stream": {
      "import": {
        "types": "./dist/client/stream.d.ts",
        "default": "./dist/client/stream.mjs"
      },
      "require": {
        "types": "./dist/client/stream.d.ts",
        "default": "./dist/client/stream.js"
      }
    },
    "./client/react": {
      "import": {
        "types": "./dist/client/react/index.d.ts",
        "default": "./dist/client/react/index.mjs"
      },
      "require": {
        "types": "./dist/client/react/index.d.ts",
        "default": "./dist/client/react/index.js"
      }
    },
    "./client/miniapp": {
      "import": {
        "types": "./dist/client/miniapp.d.ts",
        "default": "./dist/client/miniapp.mjs"
      },
      "require": {
        "types": "./dist/client/miniapp.d.ts",
        "default": "./dist/client/miniapp.js"
      }
    }
  },
  "scripts": {
    "dev": "bun bin/o2t.ts",
    "build": "bun run scripts/build.ts",
    "prepublishOnly": "npm run build",
    "serve": "hs -f apis -m index -p 7007",
    "format": "biome format --write ./src",
    "test": "bun test",
    "test:stream": "bun test src/client/stream.test.ts",
    "test:fetch": "bun test src/client/fetch.test.ts",
    "test:react": "bun test src/client/react/index.test.tsx",
    "test:petstore": "bun test src/client/tests/petstore.test.ts"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "swagger2openapi": "^7.0.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@doremijs/biome-config": "^0.1.4",
    "@swc/core": "^1.7.40",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/bun": "1.1.6",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.14.9",
    "@types/react": "^19.2.14",
    "@types/swagger2openapi": "^7.0.4",
    "bun-plugin-dts": "0.4.0",
    "bun-plugin-isolated-decl": "^0.1.0",
    "jsdom": "^29.0.1",
    "openapi-types": "^12.1.3",
    "oxc-transform": "^0.16.3",
    "react": "^19.0.0",
    "typescript": "^5.5.2"
  }
}
